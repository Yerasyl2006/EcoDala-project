# Copy this file to keystore.properties for release builds.
# Never commit keystore.properties with real passwords.

ECODALA_RELEASE_STORE_FILE=C\:\\Users\\YOUR_USER\\keystores\\ecodala-release.jks
ECODALA_RELEASE_STORE_PASSWORD=change-me
ECODALA_RELEASE_KEY_ALIAS=ecodala
ECODALA_RELEASE_KEY_PASSWORD=change-me
